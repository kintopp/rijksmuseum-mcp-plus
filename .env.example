# Example environment configuration for rijksmuseum-mcp-plus.
# Copy to `.env` (gitignored) and fill in as needed. All values below are
# safe placeholders or documented defaults — no real secrets.
# The authoritative reference is CLAUDE.md's "Environment Variables" table.

# ── Transport ──────────────────────────────────────────────────────────
# Setting PORT switches the server into HTTP mode (default is stdio).
PORT=3000
# Public base URL used to build viewer links (HTTP mode).
PUBLIC_URL=http://localhost:3000
# CORS origins on the HTML routes (response headers). Default: *
ALLOWED_ORIGINS=*
# Server-side Origin allowlist for /mcp (DNS-rebinding mitigation, spec MUST).
# Comma-separated exact origins or hostname globs (*.foo.example); replaces
# the built-in defaults (claude.ai / chatgpt.com / *.openai.com / …).
# Set to * to disable (logged at startup).
# MCP_ALLOWED_ORIGINS=claude.ai,*.claude.ai,chatgpt.com,*.chatgpt.com

# ── Database paths / download URLs ─────────────────────────────────────
# Local SQLite paths (defaults shown). *_URL is an optional gzip download
# URL fetched at startup if the local file is absent.
VOCAB_DB_PATH=data/vocabulary.db
# VOCAB_DB_URL=
EMBEDDINGS_DB_PATH=data/embeddings.db
# EMBEDDINGS_DB_URL=

# ── Embedding model ────────────────────────────────────────────────────
EMBEDDING_MODEL_ID=Xenova/multilingual-e5-small
# HuggingFace cache dir (read by the transformers library, e.g. /data/hf-cache).
# HF_HOME=

# ── Feature flags ──────────────────────────────────────────────────────
# Set false to disable the find_similar tool entirely.
ENABLE_FIND_SIMILAR=true
# Set false to disable just the Theme channel inside find_similar.
ENABLE_THEME_SIMILAR=true
# Set false to disable outputSchema + structuredContent (buggy-client workaround).
# STRUCTURED_CONTENT=
# Set 1 to skip the eager stdio warm-up (caches build lazily).
# MCP_SKIP_STARTUP_WARM=
# MCP_TEXT_JSON_COMPAT=true   # also expose serialized JSON in a 2nd text block (size-guarded).
#   Enable ONLY for programmatic / generic-connector clients that parse content[].text as JSON.
#   Do NOT enable for Claude: claude.ai/Desktop read the prose text (NOT structuredContent), so
#   the JSON copy is redundant token cost; Claude Code reads structuredContent and is token-capped.

# ── Ops ────────────────────────────────────────────────────────────────
# Tool-call metrics file.
USAGE_STATS_PATH=data/usage-stats.json

# RAILWAY_GIT_COMMIT_SHA and RAILWAY_PUBLIC_DOMAIN are read by the code but are
# auto-injected by the Railway platform at deploy time — do not set them here.
