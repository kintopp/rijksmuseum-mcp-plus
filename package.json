{
  "name": "rijksmuseum-mcp-plus",
  "version": "0.23.1",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "main": "dist/index.js",
  "bin": {
    "rijksmuseum-mcp-plus": "./dist/index.js"
  },
  "scripts": {
    "build:peggy": "peggy --format es -o src/provenance-parser.generated.js src/provenance-grammar.peggy",
    "build": "npm run build:peggy && npm run build:ui && tsc && cp src/provenance-parser.generated.js dist/ && git rev-parse --short HEAD > dist/commit.txt 2>/dev/null || true",
    "build:ui": "vite build -c apps/artwork-viewer/vite.config.ts",
    "start": "node dist/index.js",
    "serve": "node dist/index.js --http",
    "dev:viewer": "vite dev -c apps/artwork-viewer/vite.config.ts",
    "lint": "eslint src/",
    "test": "node scripts/tests/test-pure-functions.mjs",
    "test:viewer-build": "node scripts/tests/test-viewer-build.mjs",
    "test:all": "node scripts/tests/test-pure-functions.mjs && node scripts/tests/test-provenance-parser.mjs && node scripts/tests/test-provenance-peg.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "3.8.1",
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.3.5",
    "openseadragon": "^6.0.2",
    "sqlite-vec": "0.1.9",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@mcpjam/sdk": "^0.8.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "peggy": "^5.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
